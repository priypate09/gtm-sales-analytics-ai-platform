# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Salesforce (only needed when data_source: sfdc_api in company_config.yaml)
SFDC_INSTANCE_URL=https://yourorg.my.salesforce.com
SFDC_CLIENT_ID=your_sfdc_client_id
SFDC_CLIENT_SECRET=your_sfdc_client_secret
SFDC_USERNAME=your_sfdc_username

# Kaggle (only needed when data_source: kaggle in company_config.yaml)
KAGGLE_API_KEY=your_kaggle_api_key
KAGGLE_DATASET_SLUG=username/dataset-name