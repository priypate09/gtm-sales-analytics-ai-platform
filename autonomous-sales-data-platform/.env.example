# Copy to ".env" in this folder. ".env" is gitignored.

# Preferred: new Kaggle API token (Settings → API; value like KGAT_...)
# This is the same secret Kaggle documents as KAGGLE_API_TOKEN — not the old username/key pair.
KAGGLE_API_TOKEN=

# Legacy only: from kaggle.json / "Create Legacy API Key"
# KAGGLE_USERNAME=
# KAGGLE_KEY=

OPENAI_API_KEY=
